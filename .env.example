# ========================================
# JanAI - Environment Variables Template
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# --- AWS ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# --- Twilio (from Somya) ---
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+18312988145

# --- Sarvam AI TTS (primary, better Hindi quality) ---
SARVAM_API_KEY=your_sarvam_api_key_here

# --- AWS Bedrock primary LLM (Amazon-native, works with Indian billing) ---
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- OpenAI (set key and change LLM_PROVIDER to openai to use instead) ---
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=bedrock

# --- DynamoDB Table Names ---
DYNAMODB_CALLS_TABLE=janai-calls
DYNAMODB_KNOWLEDGE_TABLE=janai-knowledge
DYNAMODB_VECTORS_TABLE=janai-vectors

# --- S3 ---
S3_DOCUMENTS_BUCKET=janai-documents

# --- Auth ---
JWT_SECRET=your_jwt_secret_here
DYNAMODB_USERS_TABLE=janai-users

# --- Optional TTS providers (Cartesia, ElevenLabs for testing only) ---
CARTESIA_API_KEY=your_cartesia_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# --- WebSocket ---
DYNAMODB_WS_CONNECTIONS_TABLE=janai-ws-connections

# --- data.gov.in (optional — live scheme data) ---
DATA_GOV_API_KEY=your_data_gov_api_key_here

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
